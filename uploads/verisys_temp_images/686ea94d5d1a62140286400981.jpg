	<style>
		.slow-internet-msg {
			position: fixed; 
			left: 0px; 
			right: 0px; 
			height: 80px; 
			min-height: 21px; 
			z-index: 255; 
			background: rgb(0, 0, 0); 
			color: rgb(221, 221, 221); 
			line-height: 21px; 
			padding: 18px 16px; 
			font-family: arial, sans-serif; 
			font-size: 17px; 
			text-align: center; 
			bottom: 0px; 
			opacity: 1;
		}
		
	</style>

	<script type="text/javascript">
		var internetSlow = false;
	    var slowLoad = window.setTimeout( function() {
	    	internetSlow = true;
	    }, 10 );
	    
	    window.addEventListener( 'load', function() {
	        window.clearTimeout( slowLoad );
	        
	        internetSlow = false;
	        
	        if(internetSlow) {
	        	//alert( "Your internet connection is slow" );
	        	console.log( "Your internet connection is slow" );
	        	
	        	var internetSlowMsg = document.createElement('div');
	        	internetSlowMsg.setAttribute('id', 'slow-internet-msg');
	        	internetSlowMsg.setAttribute('class', 'slow-internet-msg');
	        	internetSlowMsg.innerHTML = '<div class="cookiebanner-close" style="float: left; padding-left: 5px; cursor: pointer;"><span>✖</span></div><span>Your internet connection is slow..</span>';
	        	document.getElementsByTagName('footer')[0].appendChild(internetSlowMsg);
	        }
	        
	        if(document.getElementById('slow-internet-msg')) {
	        		document.getElementById('slow-internet-msg').onclick = function(){
	        		document.getElementById('slow-internet-msg').style.display = 'none';
	        	}
	        }
	        
	        
	    }, false );
	</script>
